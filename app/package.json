{
  "name": "nodejs-docker-example",
  "version": "1.0.0",
  "description": "A minimal Node.js TypeScript application.",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:css && npm run build:frontend && tsc",
    "build:css": "tailwindcss -i ./public/css/tailwind.input.css -o ./public/css/tailwind.css",
    "build:frontend": "tsc -p ./public/tsconfig.frontend.json",
    "watch:css": "tailwindcss -i ./public/css/tailwind.input.css -o ./public/css/tailwind.css --watch",
    "watch:frontend": "tsc -p ./public/tsconfig.frontend.json --watch",
    "start": "node dist/server.js",
    "dev:server": "nodemon --watch src --watch views --ext ts,ejs --exec tsx src/server.ts",
    "dev": "concurrently \"npm run watch:css\" \"npm run watch:frontend\" \"npm run dev:server\"",
    "seed": "tsx src/seed.ts",
    "seed:dist": "node dist/seed.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "ejs": "^6.0.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "file-type": "^21.3.4",
    "helmet": "^8.2.0",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.2",
    "nodemailer": "^9.0.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.3",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
