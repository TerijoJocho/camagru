<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head'); %> <%-
    include('../partials/errorsAndSuccess'); %>
    <script type="module" src="/js/forgotPassword.js" defer></script>
  </head>

  <body>
    <main class="flex items-center justify-center min-h-screen">
      <div
        class="w-full max-w-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-8"
      >
        <div class="mb-7">
          <h2 class="text-xl font-medium text-gray-900 dark:text-white">
            Verifying your account
          </h2>
          <p class="text-sm text-gray-400 mt-1">
            To reset your password we need your email
          </p>
        </div>
        <form id="forgot-password-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div>
            <label
              class="block text-xs font-medium text-gray-500 mb-1.5"
              for="email"
              >Email</label
            >
            <input
              type="email"
              name="email"
              placeholder="camagru@gmail.com"
              required
              class="w-full rounded-md border border-gray-200 dark:border-gray-600 px-3 py-2 text-sm text-gray-900 dark:text-white dark:bg-gray-700 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500"
            />
          </div>
          <button
            id="forgot-password-btn"
            type="submit"
            class="w-full bg-violet-500 hover:bg-violet-400 text-white rounded-md py-2 text-sm font-medium transition-colors mt-2"
          >
            Send
          </button>
        </form>
      </div>
    </main>

    <footer><%- include('../partials/footer'); %></footer>
  </body>
</html>
