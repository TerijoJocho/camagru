<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head'); %>
  <script type="module" src="/js/profile.js" defer></script>
</head>
  <body class="">

    <header>
      <%- include('../partials/header'); %>
      <%- include('../partials/errorsAndSuccess'); %>
    </header>

    <main class="flex items-center justify-center min-h-screen">
      <div class="w-full max-w-xl bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl p-8 m-6">
        <div>
          <div class="mb-4">
            <h2 class="text-xl font-medium text-gray-900">Hi <%= user?.username %>, this is your profile</h2>
            <p class="text-sm text-gray-400 mt-1">You can change all of your informations here</p>
          </div>

          <form id="change-profile-form" class="space-y-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1.5">Username</label>
              <input type="text" name="username" placeholder="<%= user?.username %>"
                  class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500">
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1.5">Email</label>
              <input type="email" name="email" placeholder="<%= user?.email %>"
                  class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500">
            </div>
            <div>
              <p class="text-xs text-gray-400 "><em>Account created on the <%= new Date(user?.createdAt).toLocaleDateString('en-EN') %></em></p>
            </div>

            <button type="submit" id="change-profile-btn"
              class="w-full bg-violet-500 hover:bg-violet-400 text-white rounded-md py-2 text-sm font-medium transition-colors mt-2">
                Update changes
            </button>
          </form>
        </div>

        <div class="mt-16">
          <h2 class="text-xl font-medium text-gray-900 mb-4">Password settings</h2>

          <form id="change-password-form" class="space-y-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1.5">Current password</label>
              <input type="password" name="currentPassword" placeholder="************" required
                  class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500">
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1.5">New password</label>
              <input type="password" name="newPassword" placeholder="************" required
                  class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500">
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1.5">Confirm new password</label>
              <input type="password" name="confirmNewPassword" placeholder="************" required
                  class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500">
            </div>

            <button type="submit" id="change-password-btn"
              class="w-full bg-violet-500 hover:bg-violet-400 text-white rounded-md py-2 text-sm font-medium transition-colors mt-2">
                Change password
            </button>
          </form>
        </div>

        <div class="mt-16">
          <h2 class="text-xl font-medium text-gray-900">User preferences</h2>

          <form id="notifications-form" class="space-y-4 mt-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="flex">
                <div class="flex items-center h-5">
                    <input
                      type="checkbox"
                      id="email-notifications-input"
                      name="emailNotifications"
                      class="w-4 h-4 border border-default-medium rounded-xs bg-neutral-secondary-medium focus:ring-2 focus:ring-brand-soft"
                      <% if (user?.emailNotifications) { %> checked <% } %>
                    >
                </div>
                <div class="ms-2 text-sm select-none">
                    <label for="emailNotifications" class="font-medium text-heading">Email notifications</label>
                    <p class="text-xs font-normal text-body text-gray-500 mb-1.5"><em>Send me email notifications when someone interact with my posts</em></p>
                </div>
            </div>
          </form>

        </div>
      </div>
    </main>


    <footer>
      <%- include('../partials/footer'); %>
    </footer>
  </body>
</html>
