<!DOCTYPE html>
<html lang="fr">
  <head>
    <%- include('../partials/head'); %>
    <script type="module" src="/js/create.js" defer></script>
  </head>

  <body class="h-screen flex flex-col overflow-hidden">
    <header class="">
      <%- include('../partials/header'); %>
      <%-include('../partials/errorsAndSuccess'); %>
    </header>

    <main class="flex-1 p-8 overflow-hidden">
      <div class="grid h-full grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- ==================== -->
        <!--      Création        -->
        <!-- ==================== -->
        <section class="flex flex-col gap-4 min-h-0">
          <!-- Webcam / Canvas -->
          <div class="relative flex-1 overflow-hidden rounded-md bg-black">
            <video
              id="webcam"
              autoplay
              playsinline
              class="absolute inset-0 w-full h-full object-contain"
            ></video>

            <canvas id="canvas" class="absolute inset-0 w-full h-full">
            </canvas>
          </div>

          <!-- Stickers -->
          <div
            id="sticker-list"
            class="flex gap-2 overflow-x-auto rounded-md p-2 bg-yellow-300"
          ></div>

          <!-- Réglages -->
          <div class="flex gap-6">
            <label class="flex flex-col">
              Taille
              <input
                id="scale"
                type="range"
                min="0.2"
                max="3"
                step="0.1"
                value="1"
              />
            </label>

            <label class="flex flex-col">
              Rotation
              <input
                id="rotation"
                type="range"
                min="-180"
                max="180"
                value="0"
              />
            </label>
          </div>

          <!-- Actions -->
          <div class="flex gap-4 items-center">
            <button
              id="capture-btn"
              disabled
              class="bg-violet-500 text-white px-4 py-2 rounded-md opacity-50"
            >
              Capture
            </button>

            <input type="file" id="upload-input" accept="image/*" />
          </div>
        </section>

        <!-- ==================== -->
        <!--       Galerie        -->
        <!-- ==================== -->

        <section class="min-h-0">
          <div
            id="user-pictures"
            class="grid h-full grid-cols-2 gap-4 overflow-y-auto rounded-md bg-green-300 p-4"
          ></div>
        </section>
      </div>
    </main>

    <!-- ==================== -->
    <!--       Delete modal   -->
    <!-- ==================== -->
    <div
      id="delete-modal"
      class="fixed inset-0 hidden items-center justify-center bg-black/50 z-50"
    >
      <div class="bg-white rounded-lg p-6 w-80">
        <h2 class="text-lg font-semibold mb-4">Delete this picture?</h2>

        <p class="text-xs font-normal text-body text-gray-500 mb-6">
          Are you sure you want to delete this picture?
        </p>

        <form id="delete-form">
          <input type="hidden" id="delete-picture-id" name="pictureId" />

          <div class="flex justify-end gap-2">
            <button
              type="button"
              id="cancel-delete"
              class="px-4 py-2 rounded bg-gray-300"
            >
              No
            </button>
            <button
              type="submit"
              id="confirm-delete"
              class="px-4 py-2 rounded bg-red-600 text-white"
            >
              Yes
            </button>
          </div>
        </form>
      </div>
    </div>

    <footer class=""><%- include('../partials/footer'); %></footer>
  </body>
</html>
