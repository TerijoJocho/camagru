<!DOCTYPE html>
<html lang="fr">
  <head>
    <%- include('../partials/head'); %>
    <script type="module" src="/js/create.js" defer></script>
  </head>

  <body class="h-auto lg:h-screen flex flex-col overflow-y-auto lg:overflow-hidden">
    <header class="">
      <%- include('../partials/header'); %>
      <%-include('../partials/errorsAndSuccess'); %>
    </header>

    <main class="flex-1 p-4 sm:p-8 overflow-y-auto lg:overflow-hidden">
      <div class="grid h-auto lg:h-full grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-8">
        <!-- ==================== -->
        <!--      Création        -->
        <!-- ==================== -->
        <section class="flex flex-col gap-3 sm:gap-4 min-h-0">
          <!-- Webcam / Canvas -->
          <div
            id="webcam-container"
            class="relative h-[260px] sm:h-[340px] lg:h-auto lg:flex-1 overflow-hidden rounded-md bg-black"
          >
            <video
              id="webcam"
              autoplay
              playsinline
              muted
              class="absolute inset-0 w-full h-full object-contain"
            ></video>

            <canvas id="canvas" class="absolute inset-0 w-full h-full">
            </canvas>
          </div>

          <!-- Stickers -->
          <div
            id="sticker-list"
            class="flex gap-2 overflow-x-auto rounded-md p-2 bg-white"
          ></div>

          <!-- Réglages -->
          <div class="flex flex-col gap-6 sm:flex-row gap-3 sm:gap-6">
            <label class="flex flex-col text-sm">
              Size
              <input
                id="scale"
                type="range"
                min="0.2"
                max="2"
                step="0.1"
                value="1"
				class="accent-violet-500"
              />
            </label>

            <label class="flex flex-col text-sm">
              Rotation
              <input
                id="rotation"
                type="range"
                min="-180"
                max="180"
                value="0"
				class="accent-violet-500"
              />
            </label>
          </div>

          <!-- Actions -->
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 sm:items-center">
            <button
              id="webcam-toggle"
              type="button"
              class="text-white px-4 py-2 rounded-md text-sm sm:text-base"
            >
              Disable the webcam
            </button>

            <button
              id="capture-btn"
              class="bg-violet-500 text-white px-4 py-2 rounded-md text-sm sm:text-base"
              disabled
            >
              Capture
            </button>

            <input type="file" id="upload-input" accept="image/*" />
          </div>
        </section>

        <!-- ==================== -->
        <!--       Galerie        -->
        <!-- ==================== -->

        <section class="min-h-0">
          <div
            id="user-pictures"
            class="grid h-full grid-cols-2 sm:grid-cols-3 lg:grid-cols-2 gap-3 sm:gap-4 overflow-y-auto rounded-md bg-white/30 backdrop-blur-sm p-3 sm:p-4"
          ></div>
        </section>
      </div>
    </main>

    <!-- ==================== -->
    <!--       Delete modal   -->
    <!-- ==================== -->
    <div
      id="delete-modal"
      class="fixed inset-0 hidden items-center justify-center bg-black/50 z-50 px-4"
    >
      <div class="bg-white rounded-lg p-6 w-full max-w-xs sm:w-80">
        <h2 class="text-lg font-semibold mb-4">Delete this picture?</h2>

        <p class="text-xs font-normal text-body text-gray-500 mb-6">
          Are you sure you want to delete this picture?
        </p>

        <form id="delete-form">
          <input type="hidden" id="delete-picture-id" name="pictureId" />

          <div class="flex justify-end gap-2">
            <button
              type="button"
              id="cancel-delete"
              class="px-4 py-2 rounded bg-gray-300"
            >
              No
            </button>
            <button
              type="submit"
              id="confirm-delete"
              class="px-4 py-2 rounded bg-red-600 text-white"
            >
              Yes
            </button>
          </div>
        </form>
      </div>
    </div>

    <footer><%- include('../partials/footer'); %></footer>
  </body>
</html>
