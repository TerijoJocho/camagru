<script type="module" src="/js/logout.js" defer></script>
<script type="module" src="/js/header.js" defer></script>

<nav class="relative bg-gray-800/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-2">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center gap-2 sm:gap-4">
        <h1 class="px-2 sm:px-3 text-xl sm:text-2xl font-bold text-violet-400">Camagru</h1>

        <button
          id="nav-toggle"
          class="rounded-md p-2 mr-2 text-violet-400 hover:bg-white/5 hover:text-white sm:hidden"
          aria-controls="mobile-nav"
          aria-expanded="false"
          type="button"
        >
          <i class="fa-solid fa-bars"></i>
        </button>

        <div id="desktop-nav" class="hidden sm:block">
          <div class="flex space-x-4">
            <a href="/pages/gallery" class="rounded-md bg-violet-950/50 px-3 py-2 text-sm font-medium text-white hover:bg-violet/50">Gallery</a>
            <% if (user) { %>
              <a href="/pages/create" class="rounded-md px-3 py-2 text-sm font-medium text-violet-300 hover:bg-white/5 hover:text-white">Create</a>
              <a href="/pages/profile" class="rounded-md px-3 py-2 text-sm font-medium text-violet-300 hover:bg-white/5 hover:text-white">Profile</a>
            <% } %>
          </div>
        </div>
      </div>

      <% if (user) { %>
        <div class="flex items-center gap-2 sm:gap-3">
          <span class="rounded-full bg-violet-700 px-3 py-1 text-sm text-gray-300"><%= user.username %></span>
          <form id="logout-form">
            <button id="logout-btn" type="submit" class="rounded-md bg-red-500 px-2 py-1 text-sm text-white transition-colors hover:bg-red-600">
              <i class="fa-solid fa-arrow-right-from-bracket"></i>
            </button>
          </form>
        </div>
      <% } else { %>
        <div class="flex flex-col gap-2 rounded-md bg-violet-400 px-3 py-2 sm:flex-row sm:items-center sm:gap-4">
          <a href="/pages/login" class="text-xs sm:text-sm font-medium text-white hover:underline">Log in</a>
          <a href="/pages/signup" class="text-xs sm:text-sm font-medium text-white hover:underline">Sign up</a>
        </div>
      <% } %>
    </div>

    <div id="mobile-nav" class="mt-3 hidden sm:hidden">
      <div class="flex flex-col gap-2 rounded-md bg-gray-800 px-3 py-3">
        <a href="/pages/gallery" class="rounded-md px-3 py-2 text-sm font-medium text-white hover:bg-white/5">Gallery</a>
        <% if (user) { %>
          <a href="/pages/create" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-white/5 hover:text-white">Create</a>
          <a href="/pages/profile" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-white/5 hover:text-white">Profile</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
